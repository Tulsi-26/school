// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  OWNER
  SUPER_ADMIN
}

model Organization {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  slug        String   @unique
  code        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  ownerId     String?  // The user who owns the organization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     User[]
  invitations Invitation[]
  labReports  LabReport[]
  feeRecords  FeeRecord[]
  projects    Project[]
}

model FeeRecord {
  id               String       @id @default(cuid()) @map("_id")
  studentId        String
  studentName      String
  amountPaid       Float
  totalAmount      Float
  status           String       // "PAID", "PARTIAL", "PENDING"
  dueDate          DateTime?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([studentId])
}

model Project {
  id               String       @id @default(cuid()) @map("_id")
  title            String
  description      String?
  status           String       // "ACTIVE", "COMPLETED", "ARCHIVED"
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
}

model User {
  id                   String                @id @default(cuid()) @map("_id")
  name                 String?
  email                String                @unique
  image                String?
  passwordHash         String?
  phone                String?
  role                 UserRole              @default(STUDENT)
  position             String?
  address              String?
  bio                  String?
  emailVerified        DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organizationId       String?
  organization         Organization?         @relation(fields: [organizationId], references: [id])
  accounts             Account[]
  sessions             Session[]
  verificationTokens   EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  labReports           LabReport[]
  experimentSessions   ExperimentSession[]

  @@index([organizationId])
}

model LabReport {
  id               String       @id @default(cuid()) @map("_id")
  title            String
  experimentId     String
  experimentTitle  String
  aim              String
  apparatus        String[]
  theory           String
  observations     Json
  calculations     String?
  result           String
  conclusion       String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([experimentId])
}

model ExperimentSession {
  id               String   @id @default(cuid()) @map("_id")
  experimentId     String
  experimentTitle  String
  instruments      Json
  connections      Json
  observations     Json
  checklist        Json
  simulationResults Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([experimentId])
  @@index([userId, experimentId])
}

model EmailVerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id         String   @id @default(cuid()) @map("_id")
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  oauth_token_secret String?
  oauth_token       String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
model Invitation {
  id             String    @id @default(cuid()) @map("_id")
  organizationId String
  email          String
  tokenHash      String    @unique
  role           UserRole  @default(TEACHER)
  invitedBy      String    // User ID who sent the invite
  expiresAt      DateTime
  isUsed         Boolean   @default(false)
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}
